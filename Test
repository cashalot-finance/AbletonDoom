<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Math DAW - Pro Edition</title>
    <style>
        :root {
            --bg-color: #121212;
            --panel-bg: #222;
            --track-bg: #2a2a2a;
            --accent: #00d2ff;
            --accent-hover: #3a86ff;
            --text: #eee;
            --grid-off: #333;
            --grid-on: #00d2ff;
            --grid-active: #fff;
            --font: 'Inter', 'Segoe UI', sans-serif;
        }

        body {
            font-family: var(--font); background-color: var(--bg-color); color: var(--text);
            margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center;
            user-select: none;
        }

        .header { display: flex; justify-content: space-between; width: 100%; max-width: 900px; margin-bottom: 20px; }
        h1 { margin: 0; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; color: var(--accent); }

        .master-controls {
            display: flex; gap: 20px; background: var(--panel-bg); padding: 15px 25px;
            border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.6); align-items: center;
        }

        button.play-btn {
            background: var(--accent); color: #000; border: none; padding: 10px 30px;
            font-size: 16px; font-weight: bold; border-radius: 4px; cursor: pointer; transition: 0.2s;
        }
        button.play-btn:hover { background: var(--accent-hover); color: white; }

        .knob-group { display: flex; flex-direction: column; align-items: center; gap: 5px; font-size: 12px; color: #aaa; }
        input[type=range] { width: 80px; accent-color: var(--accent); cursor: pointer; }

        .daw-container {
            display: flex; flex-direction: column; gap: 10px; width: 100%; max-width: 900px;
        }

        .track {
            display: flex; align-items: center; background: var(--track-bg);
            padding: 10px; border-radius: 6px; box-shadow: inset 0 2px 5px rgba(0,0,0,0.2);
        }

        .track-header { width: 220px; display: flex; flex-direction: column; gap: 8px; padding-right: 15px; border-right: 2px solid #444; }
        .track-title { font-weight: bold; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; }
        .track-params { display: flex; gap: 10px; }

        .sequencer-grid { display: flex; gap: 6px; padding-left: 15px; flex-wrap: nowrap; overflow-x: auto; }

        .step {
            width: 35px; height: 45px; background-color: var(--grid-off);
            border-radius: 4px; cursor: pointer; transition: 0.1s; border: 1px solid #222;
        }
        .step.active { background-color: var(--grid-on); box-shadow: 0 0 12px rgba(0, 210, 255, 0.4); }
        .step.playing { border: 2px solid white; transform: scale(1.05); background-color: var(--grid-active); }

        .fx-section { display: flex; gap: 15px; border-left: 1px solid #555; padding-left: 15px; margin-left: 15px; }
    </style>
</head>
<body>

    <div class="header">
        <h1>Math DAW</h1>
        <div class="master-controls">
            <button class="play-btn" id="playBtn">▶ PLAY / STOP</button>
            <div class="knob-group">
                <label>BPM: <span id="bpmVal">120</span></label>
                <input type="range" id="bpm" min="60" max="200" value="120">
            </div>
            <div class="fx-section">
                <div class="knob-group">
                    <label>Delay</label>
                    <input type="range" id="delayMix" min="0" max="100" value="20">
                </div>
                <div class="knob-group">
                    <label>Reverb</label>
                    <input type="range" id="reverbMix" min="0" max="100" value="15">
                </div>
            </div>
        </div>
    </div>

    <div class="daw-container" id="daw"></div>

<script>
    let audioCtx;
    let masterGain, delayNode, feedbackGain, reverbNode, delayMix, reverbMix;
    
    // Параметры синтеза для каждого инструмента
    const synths = [
        { name: 'KICK', p1Name: 'Pitch', p2Name: 'Decay', p1: 150, p2: 0.5, p1Min: 50, p1Max: 300, p2Min: 0.1, p2Max: 1.5 },
        { name: 'SNARE', p1Name: 'Snap', p2Name: 'Decay', p1: 250, p2: 0.2, p1Min: 100, p1Max: 500, p2Min: 0.1, p2Max: 0.6 },
        { name: 'HI-HAT', p1Name: 'Color', p2Name: 'Decay', p1: 10000, p2: 0.05, p1Min: 5000, p1Max: 15000, p2Min: 0.02, p2Max: 0.2 },
        { name: 'BASS', p1Name: 'Cutoff', p2Name: 'Res', p1: 1000, p2: 10, p1Min: 100, p1Max: 3000, p2Min: 1, p2Max: 30 },
        { name: 'FM LEAD', p1Name: 'Mod', p2Name: 'Freq', p1: 500, p2: 440, p1Min: 0, p1Max: 2000, p2Min: 100, p2Max: 880 }
    ];

    const stepsCount = 16;
    let grid = Array(synths.length).fill().map(() => Array(stepsCount).fill(false));
    const uiSteps = [];

    // --- АУДИО ДВИЖОК ---

    function initAudio() {
        if(audioCtx) return;
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        
        masterGain = audioCtx.createGain();
        masterGain.gain.value = 0.8;
        masterGain.connect(audioCtx.destination);

        // Математический Reverb (Генерация Impulse Response)
        let len = audioCtx.sampleRate * 2.5; // 2.5 секунды
        let impulse = audioCtx.createBuffer(2, len, audioCtx.sampleRate);
        for (let i = 0; i < 2; i++) {
            let channel = impulse.getChannelData(i);
            for (let j = 0; j < len; j++) {
                channel[j] = (Math.random() * 2 - 1) * Math.pow(1 - j / len, 4); // Экспоненциальное затухание шума
            }
        }
        reverbNode = audioCtx.createConvolver();
        reverbNode.buffer = impulse;
        
        reverbMix = audioCtx.createGain();
        reverbMix.gain.value = 0.15;
        reverbNode.connect(reverbMix).connect(masterGain);

        // Delay Bus
        delayNode = audioCtx.createDelay();
        delayNode.delayTime.value = 0.375; // 3/16 при 120 bpm (будет обновляться)
        feedbackGain = audioCtx.createGain();
        feedbackGain.gain.value = 0.4;
        
        delayMix = audioCtx.createGain();
        delayMix.gain.value = 0.2;

        delayNode.connect(feedbackGain);
        feedbackGain.connect(delayNode);
        delayNode.connect(delayMix).connect(masterGain);
        
        // Отправляем дилей в реверб для объема
        delayNode.connect(reverbNode);
    }

    // Маршрутизатор (отправляет звук в мастер и на шины эффектов)
    function routeAudio(source) {
        source.connect(masterGain);
        source.connect(delayNode);
        source.connect(reverbNode);
    }

    // --- АЛГОРИТМЫ СИНТЕЗА ---

    function playKick(time, pitch, decay) {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.frequency.setValueAtTime(pitch, time);
        osc.frequency.exponentialRampToValueAtTime(0.01, time + decay);
        gain.gain.setValueAtTime(1, time);
        gain.gain.exponentialRampToValueAtTime(0.01, time + decay);
        osc.connect(gain); routeAudio(gain);
        osc.start(time); osc.stop(time + decay);
    }

    function playSnare(time, snapPitch, decay) {
        const osc = audioCtx.createOscillator();
        const oscGain = audioCtx.createGain();
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(snapPitch, time);
        oscGain.gain.setValueAtTime(0.8, time);
        oscGain.gain.exponentialRampToValueAtTime(0.01, time + decay);
        osc.connect(oscGain); routeAudio(oscGain);
        osc.start(time); osc.stop(time + decay);

        const bufferSize = audioCtx.sampleRate * decay;
        const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
        
        const noise = audioCtx.createBufferSource();
        noise.buffer = buffer;
        const noiseFilter = audioCtx.createBiquadFilter();
        noiseFilter.type = 'highpass'; noiseFilter.frequency.value = 1500;
        const noiseGain = audioCtx.createGain();
        noiseGain.gain.setValueAtTime(0.6, time);
        noiseGain.gain.exponentialRampToValueAtTime(0.01, time + decay);
        noise.connect(noiseFilter).connect(noiseGain); routeAudio(noiseGain);
        noise.start(time);
    }

    function playHiHat(time, color, decay) {
        const bufferSize = audioCtx.sampleRate * decay;
        const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
        
        const noise = audioCtx.createBufferSource(); noise.buffer = buffer;
        const filter = audioCtx.createBiquadFilter();
        filter.type = 'bandpass'; filter.frequency.value = color;
        const gain = audioCtx.createGain();
        gain.gain.setValueAtTime(0.8, time); gain.gain.exponentialRampToValueAtTime(0.01, time + decay);
        noise.connect(filter).connect(gain); routeAudio(gain);
        noise.start(time);
    }

    function playBass(time, cutoff, res) {
        const osc = audioCtx.createOscillator(); osc.type = 'square'; osc.frequency.value = 55;
        const filter = audioCtx.createBiquadFilter(); filter.type = 'lowpass';
        filter.Q.value = res;
        filter.frequency.setValueAtTime(cutoff, time);
        filter.frequency.exponentialRampToValueAtTime(50, time + 0.4);
        const gain = audioCtx.createGain(); gain.gain.setValueAtTime(0.7, time); gain.gain.exponentialRampToValueAtTime(0.01, time + 0.4);
        osc.connect(filter).connect(gain); routeAudio(gain);
        osc.start(time); osc.stop(time + 0.4);
    }

    function playLead(time, modIndex, baseFreq) {
        // FM Синтез
        const carrier = audioCtx.createOscillator(); carrier.type = 'sine'; carrier.frequency.value = baseFreq;
        const modulator = audioCtx.createOscillator(); modulator.type = 'sine'; modulator.frequency.value = baseFreq * 2.01; // Небольшой расстрой
        
        const modGain = audioCtx.createGain(); modGain.gain.value = modIndex;
        modulator.connect(modGain); modGain.connect(carrier.frequency); // Модулируем частоту несущей!
        
        const gain = audioCtx.createGain(); gain.gain.setValueAtTime(0.5, time); gain.gain.setTargetAtTime(0, time + 0.1, 0.1);
        carrier.connect(gain); routeAudio(gain);
        
        modulator.start(time); carrier.start(time);
        modulator.stop(time + 0.5); carrier.stop(time + 0.5);
    }

    const soundEngines = [playKick, playSnare, playHiHat, playBass, playLead];

    // --- ИНТЕРФЕЙС И ЛОГИКА ---

    const daw = document.getElementById('daw');
    synths.forEach((synth, trackIdx) => {
        const trackDiv = document.createElement('div'); trackDiv.className = 'track';
        
        // Панель управления синтезатором
        const header = document.createElement('div'); header.className = 'track-header';
        header.innerHTML = `<div class="track-title">${synth.name}</div>`;
        
        const params = document.createElement('div'); params.className = 'track-params';
        
        // Макрос 1
        const p1Div = document.createElement('div'); p1Div.className = 'knob-group';
        p1Div.innerHTML = `<label>${synth.p1Name}</label><input type="range" min="${synth.p1Min}" max="${synth.p1Max}" step="0.01" value="${synth.p1}">`;
        p1Div.querySelector('input').addEventListener('input', (e) => synths[trackIdx].p1 = parseFloat(e.target.value));
        
        // Макрос 2
        const p2Div = document.createElement('div'); p2Div.className = 'knob-group';
        p2Div.innerHTML = `<label>${synth.p2Name}</label><input type="range" min="${synth.p2Min}" max="${synth.p2Max}" step="0.01" value="${synth.p2}">`;
        p2Div.querySelector('input').addEventListener('input', (e) => synths[trackIdx].p2 = parseFloat(e.target.value));
        
        params.appendChild(p1Div); params.appendChild(p2Div); header.appendChild(params); trackDiv.appendChild(header);

        // Сетка
        const gridDiv = document.createElement('div'); gridDiv.className = 'sequencer-grid';
        uiSteps[trackIdx] = [];
        for (let i = 0; i < stepsCount; i++) {
            const step = document.createElement('div'); step.className = 'step';
            step.addEventListener('click', () => {
                grid[trackIdx][i] = !grid[trackIdx][i]; step.classList.toggle('active');
            });
            gridDiv.appendChild(step); uiSteps[trackIdx].push(step);
        }
        trackDiv.appendChild(gridDiv); daw.appendChild(trackDiv);
    });

    // Дефолтный паттерн (Doom-like Industrial Groove)
    [0, 4, 8, 10].forEach(i => { grid[0][i] = true; uiSteps[0][i].classList.add('active'); }); // Kick
    [4, 12].forEach(i => { grid[1][i] = true; uiSteps[1][i].classList.add('active'); }); // Snare
    [2, 6, 10, 14].forEach(i => { grid[2][i] = true; uiSteps[2][i].classList.add('active'); }); // Hat
    [0, 3, 6, 9, 12, 14].forEach(i => { grid[3][i] = true; uiSteps[3][i].classList.add('active'); }); // Bass
    [0, 7, 12].forEach(i => { grid[4][i] = true; uiSteps[4][i].classList.add('active'); }); // Lead

    // Глобальные контроллы
    let isPlaying = false, currentStep = 0, nextNoteTime = 0.0, bpm = 120, timerID;

    document.getElementById('bpm').addEventListener('input', (e) => {
        bpm = e.target.value; document.getElementById('bpmVal').innerText = bpm;
        if (audioCtx && delayNode) delayNode.delayTime.value = (60 / bpm) * 0.75; // Синхронизация дилея (Dotted 8th)
    });
    document.getElementById('delayMix').addEventListener('input', (e) => { if(audioCtx) delayMix.gain.value = e.target.value / 100; });
    document.getElementById('reverbMix').addEventListener('input', (e) => { if(audioCtx) reverbMix.gain.value = e.target.value / 100; });

    function scheduleNote(stepNumber, time) {
        for (let t = 0; t < synths.length; t++) {
            if (grid[t][stepNumber]) soundEngines[t](time, synths[t].p1, synths[t].p2);
        }
        requestAnimationFrame(() => {
            for (let t = 0; t < synths.length; t++) {
                uiSteps[t].forEach(s => s.classList.remove('playing'));
                uiSteps[t][stepNumber].classList.add('playing');
            }
        });
    }

    function scheduler() {
        while (nextNoteTime < audioCtx.currentTime + 0.1) {
            scheduleNote(currentStep, nextNoteTime);
            nextNoteTime += 0.25 * (60.0 / bpm);
            currentStep = (currentStep + 1) % stepsCount;
        }
        timerID = setTimeout(scheduler, 25.0);
    }

    document.getElementById('playBtn').addEventListener('click', () => {
        initAudio();
        if (audioCtx.state === 'suspended') audioCtx.resume();
        isPlaying = !isPlaying;
        if (isPlaying) {
            currentStep = 0; nextNoteTime = audioCtx.currentTime + 0.05; scheduler();
            document.getElementById('playBtn').innerText = '⏸ STOP';
        } else {
            clearTimeout(timerID);
            for (let t = 0; t < synths.length; t++) uiSteps[t].forEach(s => s.classList.remove('playing'));
            document.getElementById('playBtn').innerText = '▶ PLAY';
        }
    });
</script>
</body>
</html>
